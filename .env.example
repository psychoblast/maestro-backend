# ── Required ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Stripe billing ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Optional: Twilio SMS OTP ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Optional: D-ID talking avatars ─────────────────────────────────────────────
D_ID_API_KEY=...

# ── App URL (used for Stripe redirect + D-ID image hosting) ────────────────────
# Set to your public Railway domain after deploy, e.g.:
# APP_BASE_URL=https://maestro-production.up.railway.app
APP_BASE_URL=http://localhost:8765

# ── Path overrides (default to paths relative to main.py) ──────────────────────
# Uncomment to override if your directory layout differs from the Docker default:
# MAESTRO_DIR=/app
# SKILLS_DIR=/app/skills
# ARTISTS_DIR=/app/data/artists
# KNOWLEDGE_BASE=/app/KNOWLEDGE.md
# AUDIO_CACHE_DIR=/app/audio_cache
# DB_PATH=/app/memory.db

# ── Phase 1: Gmail OAuth ──────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Application type: Web application
# Authorised redirect URI must match Railway URL exactly (no trailing slash)
GMAIL_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-YOUR_SECRET
GMAIL_OAUTH_REDIRECT_URI=https://YOUR-RAILWAY-URL/api/gmail/callback

# ── Phase 1: Inbox scheduler ──────────────────────────────────────────────────
SCHEDULER_ENABLED=false   # set true on Railway to enable automatic inbox polling
REPLY_POLL_HOURS=6        # hours between inbox scans per artist (default 6)
