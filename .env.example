# PLMKR Environment Variables — Public Template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
#
# GUARD LEGEND:
#   [HARD EXIT]  — app calls sys.exit(1) at boot if misconfigured (see main.py line refs)
#   [SOFT 503]   — app boots fine; affected API routes return HTTP 503
#   [SOFT WARN]  — app boots fine; warning printed to Railway logs at startup
#   [OPTIONAL]   — feature disabled if unset; no warning
#   [CONFIG]     — no guard; falls back to documented default
#
# HARD EXIT SCENARIOS (will crash Railway deploy):
#   1. DATABASE_URL set + Postgres unreachable + DB_FAILOVER_TO_SQLITE != "true"
#      → sys.exit(1) in _init_pg_connection() (main.py:1182)
#   2. RAILWAY_ENVIRONMENT set (auto-injected by Railway) + STRIPE_DEV_ALLOW_UNSIGNED=true
#      → sys.exit(1) at boot (main.py:~1992)
#
# For build-stage local dev: leave Stripe and DATABASE_URL unset to take safe soft paths.
# ─────────────────────────────────────────────────────────────────────────────────────────

# ── AUTHENTICATION ────────────────────────────────────────────────────────────────────────

# [SOFT WARN] Master API key — required for all non-public routes (main.py:51).
# Public routes that bypass auth: GET /health, GET /docs, GET /redoc, GET /openapi.json, OPTIONS *
# If unset: dev-permissive mode — all routes open, startup warning logged. Never deploy without this.
# Generate: openssl rand -hex 32
PLMKR_API_KEY=your-plmkr-api-key-here

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────────────────

# [SOFT 503] Required for AI pitch/PR/booking generation and inbox reply classification.
# If unset: all /api/pitches/*, /api/pr/*, /api/booking/*, classifier routes return 503 (main.py:28).
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── GMAIL OAUTH (GCP) ─────────────────────────────────────────────────────────────────────

# [SOFT 503] All three required together. Missing any → /api/gmail/auth returns 503
# (pitch_service.py:36-38). Complete GCP Part A of RUNBOOK_MANUAL_SESSION.md first.
# Create at: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
GMAIL_OAUTH_CLIENT_ID=your-gcp-oauth-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-gcp-oauth-client-secret-here
# Must exactly match URI registered in GCP Console — no trailing slash, must be https in prod.
GMAIL_OAUTH_REDIRECT_URI=https://your-railway-url.railway.app/api/gmail/callback

# ── DATABASE ──────────────────────────────────────────────────────────────────────────────

# [HARD EXIT] Optional Postgres. If set but unreachable and DB_FAILOVER_TO_SQLITE != "true"
# → sys.exit(1) at _init_pg_connection() (main.py:1164-1182). Leave unset for SQLite (recommended
# for build stage and initial Railway deploy — use Railway Postgres add-on for scale path).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# [OPTIONAL] Allow SQLite fallback if Postgres fails. Only meaningful with DATABASE_URL set.
# DB_FAILOVER_TO_SQLITE=true

# [CONFIG] SQLite database path. Default: /data/memory.db — matches Railway persistent volume.
# Change for local dev if /data is not writable: DB_PATH=./memory.db
DB_PATH=/data/memory.db

# [CONFIG] Data directory roots. Defaults match Railway persistent volume mount at /data.
DATA_DIR=/data
ARTISTS_DIR=/data/artists
AUDIO_CACHE_DIR=/data/audio_cache
TEMP_AUDIO_DIR=static/temp_audio

# [CONFIG] Skills and knowledge base paths. Defaults are relative to /app in Docker.
SKILLS_DIR=skills
KNOWLEDGE_BASE=KNOWLEDGE.md

# ── STRIPE BILLING ────────────────────────────────────────────────────────────────────────

# [SOFT 503] Required for checkout and subscription routes.
# If unset: billing routes degrade; no hard exit.
# Use sk_test_* for initial deploy. Register webhook in Stripe dashboard (runbook Part D).
# STRIPE_SECRET_KEY=sk_test_your-stripe-test-key-here

# [SOFT 503] Webhook signing secret from Stripe dashboard → Developers → Webhooks.
# If unset: all webhook POSTs return 400 (signature verification fails).
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# [HARD EXIT] NEVER set this to true when RAILWAY_ENVIRONMENT is present (auto-set by Railway).
# → sys.exit(1) at boot to prevent unsigned webhooks in production (main.py:~1992).
# Leave unset in all Railway environments.
# STRIPE_DEV_ALLOW_UNSIGNED=true

# ── TWILIO SMS OTP ────────────────────────────────────────────────────────────────────────

# [SOFT WARN] Required for SMS OTP verification. Dev bypass active when unset or invalid.
# TWILIO_AUTH_TOKEN must be exactly 32 lowercase hex characters — warning logged if wrong
# format (main.py:820). Leave all three unset for build stage.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── BUFFER (SOCIAL POSTS) ─────────────────────────────────────────────────────────────────

# [OPTIONAL] Required for publishing social posts via Buffer.
# If unset: posts are generated but not published (accepted risk R-26).
# Create at: buffer.com/developers/apps → New App
# BUFFER_CLIENT_ID=your-buffer-client-id-here
# BUFFER_CLIENT_SECRET=your-buffer-client-secret-here
# BUFFER_REDIRECT_URI=https://your-railway-url.railway.app/api/buffer/callback

# ── OTHER PAID SERVICES ───────────────────────────────────────────────────────────────────

# [OPTIONAL] D-ID talking avatar generation. If unset: video routes return 503.
# D_ID_API_KEY=your-d-id-api-key-here

# [OPTIONAL] ElevenLabs TTS. Must be paid Starter account — free tier is flagged by Railway.
# If unset: TTS routes 503. Fallback to OpenAI TTS if OPENAI_API_KEY is set.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# [OPTIONAL] Cloudinary CDN for audio and avatar assets.
# If unset: files served from local static/; no CDN URL rewriting.
# CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name-here

# ── APP CONFIG ────────────────────────────────────────────────────────────────────────────

# [HARD EXIT on Railway] Public HTTPS base URL — used for OAuth redirect URI construction,
# billing links, and audio URL generation (main.py). R-11 fix: if unset AND RAILWAY_ENVIRONMENT
# is set (auto-injected by Railway), app calls sys.exit(1) at boot. In local dev, falls back
# to http://localhost:8000 with a boot WARNING. Set before enabling Gmail OAuth.
APP_BASE_URL=https://your-railway-url.railway.app

# [CONFIG] Comma-separated allowed CORS origins. Default: 6 hardcoded dev/staging origins
# (main.py:63). Override with your production frontend URL in Railway.
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,https://your-railway-url.railway.app

# [CONFIG] Max outreach emails per artist per calendar day. Resets at UTC midnight.
# Retry-After header is calculated to next UTC midnight (pitch_service.py:46).
DAILY_PITCH_QUOTA=50

# [CONFIG] Max upload size in bytes for /api/transcribe endpoint (main.py:~B-06 fix).
# Default: 26214400 (25 MB). Override for larger audio files.
MAX_UPLOAD_SIZE=26214400

# [CONFIG] Inbox scan interval in hours for reply detection (pitch_service.py scheduler).
REPLY_POLL_HOURS=6

# [CONFIG] Enable APScheduler for timed jobs (inbox polling, weekly reports).
# Set true ONLY after Gmail OAuth is verified working (runbook Part H).
# Risk R-27: leaving false is safe and expected until manual end-to-end test passes.
SCHEDULER_ENABLED=false

# [CONFIG] Max campaign_actions processed per scheduler tick. Prevents quota exhaustion
# on first run when many past-due actions exist (R-10 fix).
SCHEDULER_BATCH_LIMIT=10

# [CONFIG] Weekly report schedule (R-28). Defaults: Sunday 18:00 UTC.
# WEEKLY_REPORT_DAY accepts APScheduler day-of-week values: mon tue wed thu fri sat sun
# WEEKLY_REPORT_HOUR_UTC=18
# WEEKLY_REPORT_DAY=sun
# WEEKLY_REPORT_MINUTE=0

# ── OBSERVABILITY ─────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN for error tracking. If unset: no-op, Sentry disabled (no error raised).
# Obtain at: sentry.io → Project → Settings → Client Keys (DSN).
# On Railway: set SENTRY_DSN in Variables. In local dev: leave unset unless testing Sentry.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
